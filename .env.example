NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-this-nextauth-secret

# ── Google OAuth (required for production login) ──────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorised redirect URI: https://<your-domain>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Demo login (dev / staging only) ──────────────────────────────────────────
# Set to "true" to allow name+email sign-in without real OAuth.
# Disabled by default in production.
ENABLE_DEMO_AUTH=false

# ── Admin access ──────────────────────────────────────────────────────────────
# Comma-separated list of emails that can control club status via admin panel.
CLUB_ADMIN_EMAILS=

# ── Bot token signing ────────────────────────────────────────────────────────
BOT_TOKEN_SECRET=change-this-bot-token-secret

# ── Supabase (server-side only — never expose these to the browser) ───────────
# Find these in your Supabase project → Settings → API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Run supabase/schema.sql in the Supabase SQL editor to create all tables.
