NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-this-nextauth-secret

# Optional: enable real Google OAuth login
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional: enable demo login in production (default: false in production)
ENABLE_DEMO_AUTH=false
# Optional: comma-separated admin emails allowed to control club status
CLUB_ADMIN_EMAILS=

# Secret used to sign bot tokens
BOT_TOKEN_SECRET=change-this-bot-token-secret

# Supabase (server-side only)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
