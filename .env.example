# ── Supabase (primary auth + data) ───────────────────────────────────────────
# Find these in your Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-secret-key>

# ── Google OAuth via Supabase Auth ────────────────────────────────────────────
# 1. Create OAuth credentials at https://console.cloud.google.com/apis/credentials
# 2. Authorised redirect URI: https://<your-domain>/api/auth/callback
# 3. In Supabase Dashboard → Authentication → Providers → Google:
#    - Paste your Client ID and Client Secret
#    - Supabase redirect URL: https://<project-ref>.supabase.co/auth/v1/callback
# No extra env vars needed — Google is configured inside the Supabase dashboard.

# ── Demo login (dev / staging only) ──────────────────────────────────────────
# Set to "true" to allow name+email sign-in without real OAuth.
# Auto-enabled in development when not explicitly set to "false".
ENABLE_DEMO_AUTH=false

# ── Admin panel ───────────────────────────────────────────────────────────────
# Comma-separated list of emails that can manage clubs.
CLUB_ADMIN_EMAILS=

# ── Bot token signing ─────────────────────────────────────────────────────────
BOT_TOKEN_SECRET=change-this-bot-token-secret

# ── Schema ────────────────────────────────────────────────────────────────────
# Run supabase/schema.sql in the Supabase SQL editor to initialise all tables.
